NODE_ENV=development
PORT=5000
CORS_ORIGINS=http://localhost:3000
FORCE_HTTPS=false
TRUST_PROXY=1
JSON_BODY_LIMIT=1mb
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=300
AUTH_RATE_LIMIT_MAX_REQUESTS=20
MONGODB_MAX_POOL_SIZE=20
MONGODB_MIN_POOL_SIZE=5
MONGODB_SERVER_SELECTION_TIMEOUT_MS=10000
MONGODB_SOCKET_TIMEOUT_MS=45000

# Working format for this project on the current Node runtime.
MONGO_URI=mongodb://<db_user>:<db_password>@<host-00>:27017,<host-01>:27017,<host-02>:27017/taxmate?ssl=true&authSource=admin&replicaSet=<replica_set_name>&retryWrites=true&w=majority&appName=Cluster0

# If you switch to a stable Node LTS and SRV works correctly, this is the usual Atlas format:
# MONGO_URI=mongodb+srv://<db_user>:<db_password>@<cluster-host>/taxmate?retryWrites=true&w=majority&appName=Cluster0

JWT_SECRET=replace-with-a-long-random-secret
OPENAI_API_KEY=replace-with-your-openai-api-key
OPENAI_MODEL=gpt-4o-mini