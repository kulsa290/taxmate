# Development Environment Configuration
# Used for local development with hot reload and debugging enabled

NODE_ENV=development
PORT=5000
LOG_LEVEL=debug
DEBUG=true

# Database
MONGODB_URI=mongodb://localhost:27017/taxmate-dev
MONGOOSE_DEBUG=true

# Authentication
JWT_SECRET=dev-secret-key-change-in-production
JWT_EXPIRE=7d
REFRESH_TOKEN_SECRET=dev-refresh-secret

# CORS
CORS_ORIGINS=http://localhost:3000,http://localhost:5173,http://localhost:8000

# API Configuration
API_PREFIX=/api
API_VERSION=v1

# OpenAI Configuration
OPENAI_API_KEY=sk-dev-key-placeholder
OPENAI_MODEL=gpt-3.5-turbo
OPENAI_MAX_TOKENS=500

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# External Services
REDIS_URL=redis://localhost:6379
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=dev@taxmate.local
SMTP_PASS=dev

# Features
ENABLE_SWAGGER=true
ENABLE_CORS=true
ENABLE_COMPRESSION=true
ENABLE_HELMET=false

# Logging
LOG_TO_FILE=false
LOG_FORMAT=dev

# Session
SESSION_TIMEOUT=1800000

# File Upload
MAX_FILE_SIZE=10485760
UPLOAD_DIR=./uploads

# Development Tools
ENABLE_HOT_RELOAD=true
NODEMON_WATCH=src/**/*.js
NODEMON_IGNORE=node_modules,coverage

# Testing
TEST_DATABASE_URL=mongodb://localhost:27017/taxmate-test
TEST_TIMEOUT=10000
