# Karsathi Frontend - Production Environment (Vercel)
# This file is for Vercel deployment environment variables

REACT_APP_API_URL=https://api.karsathi.co.in
REACT_APP_APP_URL=https://karsathi.co.in
REACT_APP_APP_NAME=Karsathi

# Analytics (Optional)
REACT_APP_GA_ID=

# Feature Flags
REACT_APP_ENABLE_AI_RECOMMENDATIONS=true
REACT_APP_ENABLE_PDF_EXPORT=true
REACT_APP_ENABLE_BULK_OPERATIONS=true
REACT_APP_ENABLE_ANALYTICS=true

# Sentry (Error Tracking)
REACT_APP_SENTRY_DSN=

# Build Time Variables
NODE_ENV=production
