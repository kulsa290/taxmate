# Production Environment Configuration
# High-security, performance-optimized settings for production

NODE_ENV=production
PORT=5000
LOG_LEVEL=warn
DEBUG=false

# Database (MongoDB Atlas Production Cluster)
MONGODB_URI=${MONGODB_PROD_URI}
MONGODB_REPLICA_SET=${MONGODB_REPLICA_SET}
MONGODB_READ_PREFERENCE=secondary
MONGOOSE_DEBUG=false

# Connection Pooling
MONGODB_POOL_SIZE=50
MONGODB_CONNECTION_TIMEOUT=10000
MONGODB_SOCKET_TIMEOUT=45000

# Authentication
JWT_SECRET=${JWT_SECRET_PROD}
JWT_EXPIRE=24h
REFRESH_TOKEN_SECRET=${REFRESH_TOKEN_SECRET_PROD}
JWT_ALGORITHM=HS512

# CORS (Strict whitelist)
CORS_ORIGINS=https://taxmate.in,https://app.taxmate.in,https://api.taxmate.in
CORS_CREDENTIALS=true
CORS_MAX_AGE=86400

# API Configuration
API_PREFIX=/api
API_VERSION=v1
API_BASE_URL=https://api.taxmate.in
RATE_LIMIT_BYPASS_TOKEN=${RATE_LIMIT_BYPASS_TOKEN_PROD}

# OpenAI Configuration (Production API Key)
OPENAI_API_KEY=${OPENAI_API_KEY_PROD}
OPENAI_MODEL=gpt-4
OPENAI_MAX_TOKENS=1000
OPENAI_ORGANIZATION=${OPENAI_ORG_ID}

# Rate Limiting (Strict for production)
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
AUTH_RATE_LIMIT_MAX_REQUESTS=5
RATE_LIMIT_SKIP_FAILED_REQUESTS=false

# External Services
REDIS_URL=${REDIS_PROD_URL}
REDIS_PASSWORD=${REDIS_PASSWORD_PROD}
REDIS_TLS=true
REDIS_DB=0

# Email Service (SendGrid)
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_USER=apikey
SMTP_PASS=${SENDGRID_API_KEY_PROD}
SMTP_FROM=noreply@taxmate.in
SMTP_FROM_NAME=TaxMate

# Security Headers (Helmet)
ENABLE_HELMET=true
HELMET_HSTS_MAX_AGE=31536000
HELMET_HSTS_INCLUDE_SUBDOMAINS=true
HELMET_HSTS_PRELOAD=true
HELMET_CSP_ENABLED=true

# Features
ENABLE_SWAGGER=false
ENABLE_CORS=true
ENABLE_COMPRESSION=true
ENABLE_RATE_LIMIT=true
ENABLE_REQUEST_VALIDATION=true

# Logging (Structured JSON logging for log aggregation)
LOG_TO_FILE=true
LOG_FILE_PATH=/var/log/taxmate/production.log
LOG_FORMAT=json
LOG_RETENTION_DAYS=30
LOG_BUFFER_SIZE=1024
LOG_LEVEL_DEBUG=false

# ELK Stack / Log Aggregation
ELASTICSEARCH_HOST=${ELASTICSEARCH_HOST}
ELASTICSEARCH_PORT=${ELASTICSEARCH_PORT}
ELASTICSEARCH_USERNAME=${ELASTICSEARCH_USER}
ELASTICSEARCH_PASSWORD=${ELASTICSEARCH_PASS}
ELASTICSEARCH_TLS=true

# Session Management
SESSION_TIMEOUT=1800000
SESSION_STORE=redis
SESSION_SECURE_COOKIE=true
SESSION_SAME_SITE=strict

# File Upload
MAX_FILE_SIZE=52428800
UPLOAD_DIR=/var/taxmate/uploads
UPLOAD_BUCKET=taxmate-production-uploads
UPLOAD_STORAGE_TYPE=s3
AWS_S3_REGION=us-east-1
AWS_S3_ACCESS_KEY=${AWS_PROD_ACCESS_KEY}
AWS_S3_SECRET_KEY=${AWS_PROD_SECRET_KEY}

# Monitoring & Alerting
ENABLE_MONITORING=true
ENABLE_METRICS=true
ENABLE_TRACING=true

# Sentry (Error tracking)
SENTRY_DSN=${SENTRY_DSN_PROD}
SENTRY_ENVIRONMENT=production
SENTRY_TRACES_SAMPLE_RATE=0.1
SENTRY_PROFILES_SAMPLE_RATE=0.1

# Datadog (APM & Monitoring)
DATADOG_ENABLED=true
DATADOG_API_KEY=${DATADOG_API_KEY}
DATADOG_APP_KEY=${DATADOG_APP_KEY}
DATADOG_ENVIRONMENT=production
DATADOG_SERVICE=taxmate-api
DATADOG_TRACE_ENABLED=true

# NewRelic (Alternative APM)
NEW_RELIC_ENABLED=true
NEW_RELIC_LICENSE_KEY=${NEW_RELIC_LICENSE_KEY}
NEW_RELIC_APP_NAME=TaxMate Production API
NEW_RELIC_ENVIRONMENT=production

# Health Check
HEALTH_CHECK_INTERVAL=30000
ENABLE_HEALTH_ENDPOINT=true
HEALTH_CHECK_TIMEOUT=5000

# Database Backup
BACKUP_ENABLED=true
BACKUP_SCHEDULE=0 2 * * *
BACKUP_RETENTION_DAYS=90
AWS_BACKUP_BUCKET=taxmate-backups-production
BACKUP_ENCRYPTION_ENABLED=true
BACKUP_ENCRYPTION_KEY=${BACKUP_ENCRYPTION_KEY}

# Disaster Recovery
ENABLE_REPLICATION=true
REPLICATION_LAG_THRESHOLD=5000
FAILOVER_ENABLED=true
FAILOVER_TIMEOUT=30000

# Feature Flags (Production-ready features only)
FEATURE_AI_RECOMMENDATIONS=true
FEATURE_PDF_EXPORT=true
FEATURE_BULK_OPERATIONS=true
FEATURE_ANALYTICS=true
FEATURE_ADVANCED_REPORTING=true
FEATURE_API_V2=false

# Performance Optimization
ENABLE_CACHE=true
CACHE_TTL=3600
CACHE_MAX_SIZE=1000
ENABLE_PAGINATION=true
DEFAULT_PAGE_SIZE=20
MAX_PAGE_SIZE=100

# SSL/TLS
HTTPS_ENABLED=true
SSL_CERT_PATH=/etc/ssl/private/taxmate.crt
SSL_KEY_PATH=/etc/ssl/private/taxmate.key
SSL_CA_PATH=/etc/ssl/certs/ca-bundle.crt

# API Keys & Secrets (Loaded from Vault)
VAULT_ENABLED=true
VAULT_ADDR=${VAULT_ADDR}
VAULT_TOKEN=${VAULT_TOKEN}
VAULT_PATH=secret/taxmate/production

# Production-Only Features
MAINTENANCE_MODE=false
READ_ONLY_MODE=false
AUDIT_LOG_ENABLED=true
AUDIT_LOG_RETENTION_DAYS=365

# Version Management
API_VERSION_REQUIRED=1.0.0
DEPRECATION_WARNINGS=true

# Compliance
GDPR_ENABLED=true
PII_MASKING=true
DATA_RETENTION_DAYS=2555
ENCRYPTION_ENABLED=true
