# Staging Environment Configuration
# Pre-production environment mirroring production with test data

NODE_ENV=staging
PORT=5000
LOG_LEVEL=info
DEBUG=false

# Database
# Use MongoDB Atlas staging cluster
MONGODB_URI=mongodb+srv://staging-user:${STAGING_DB_PASSWORD}@taxmate-staging.mongodb.net/taxmate-staging?retryWrites=true&w=majority
MONGOOSE_DEBUG=false

# Authentication
JWT_SECRET=${JWT_SECRET_STAGING}
JWT_EXPIRE=7d
REFRESH_TOKEN_SECRET=${REFRESH_TOKEN_SECRET_STAGING}

# CORS
CORS_ORIGINS=https://staging.taxmate.in,https://api-staging.taxmate.in

# API Configuration
API_PREFIX=/api
API_VERSION=v1
API_BASE_URL=https://api-staging.taxmate.in

# OpenAI Configuration (Test API Key)
OPENAI_API_KEY=${OPENAI_API_KEY_STAGING}
OPENAI_MODEL=gpt-3.5-turbo
OPENAI_MAX_TOKENS=500

# Rate Limiting (Relaxed for testing)
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=500

# External Services
REDIS_URL=redis://redis-staging:6379
REDIS_PASSWORD=${REDIS_PASSWORD_STAGING}
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_USER=apikey
SMTP_PASS=${SENDGRID_API_KEY_STAGING}

# Features
ENABLE_SWAGGER=true
ENABLE_CORS=true
ENABLE_COMPRESSION=true
ENABLE_HELMET=true

# Logging
LOG_TO_FILE=true
LOG_FILE_PATH=./logs/staging.log
LOG_FORMAT=json
LOG_RETENTION_DAYS=7

# Session
SESSION_TIMEOUT=3600000
SESSION_STORE=redis

# File Upload
MAX_FILE_SIZE=52428800
UPLOAD_DIR=/var/taxmate/uploads
UPLOAD_BUCKET=taxmate-staging-uploads

# Monitoring
ENABLE_MONITORING=true
SENTRY_DSN=${SENTRY_DSN_STAGING}
SENTRY_ENVIRONMENT=staging
SENTRY_TRACES_SAMPLE_RATE=0.1

# Database Backup
BACKUP_ENABLED=true
BACKUP_SCHEDULE=0 3 * * *
AWS_BACKUP_BUCKET=taxmate-backups-staging

# Health Check
HEALTH_CHECK_INTERVAL=60000
ENABLE_HEALTH_ENDPOINT=true

# Feature Flags
FEATURE_AI_RECOMMENDATIONS=true
FEATURE_PDF_EXPORT=true
FEATURE_BULK_OPERATIONS=true
FEATURE_ANALYTICS=true

# Staging-Specific
TEST_DATA_SEED=true
TEST_DATA_RESET_DAILY=false
DEMO_MODE=false
